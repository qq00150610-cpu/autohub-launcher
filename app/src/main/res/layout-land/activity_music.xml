<?xml version="1.0" encoding="utf-8"?>
<!-- 音乐播放器布局 - 横屏模式 -->
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".MusicPlayerActivity">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_size_xl"
            android:layout_height="@dimen/icon_size_xl"
            android:src="@drawable/ic_hide"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:padding="@dimen/spacing_sm"/>

        <!-- 标题 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/music_player"
            android:textSize="@dimen/text_size_lg"
            android:textColor="@color/text_on_primary"
            android:gravity="center"/>

        <!-- 更多按钮 -->
        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="@dimen/icon_size_xl"
            android:layout_height="@dimen/icon_size_xl"
            android:src="@drawable/ic_notification"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings"
            android:padding="@dimen/spacing_sm"/>
    </LinearLayout>

    <!-- 左半部分 - 专辑封面 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/albumCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="@dimen/corner_radius_lg"
        app:cardElevation="8dp"
        android:layout_margin="@dimen/spacing_lg"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintVertical_bias="0.5">

        <ImageView
            android:id="@+id/ivAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music"
            android:contentDescription="@string/music_player"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- 水平引导线 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.45"/>

    <!-- 右半部分 - 播放控制 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_lg"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 歌曲信息 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/unknown_title"
            android:textSize="@dimen/text_size_xxl"
            android:textColor="@color/text_primary_dark"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/unknown_artist"
            android:textSize="@dimen/text_size_lg"
            android:textColor="@color/text_secondary_dark"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_sm"/>

        <!-- 进度条区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_xl">

            <!-- SeekBar进度条 -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary"/>

            <!-- 时间显示 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textSize="@dimen/text_size_sm"
                    android:textColor="@color/text_secondary_dark"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textSize="@dimen/text_size_sm"
                    android:textColor="@color/text_secondary_dark"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 播放控制按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_lg">

            <!-- 随机播放按钮 -->
            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_notification"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/shuffle"
                android:padding="@dimen/spacing_sm"/>

            <!-- 上一首按钮 -->
            <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous"
                android:padding="@dimen/spacing_sm"
                android:layout_marginStart="@dimen/spacing_md"/>

            <!-- 播放/暂停按钮 -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="@dimen/player_control_size_large"
                android:layout_height="@dimen/player_control_size_large"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_floating_ball"
                android:contentDescription="@string/play"
                android:padding="@dimen/spacing_md"
                android:layout_marginHorizontal="@dimen/spacing_lg"/>

            <!-- 下一首按钮 -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:padding="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_md"/>

            <!-- 循环播放按钮 -->
            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_notification"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/repeat"
                android:padding="@dimen/spacing_sm"/>
        </LinearLayout>

        <!-- 播放列表按钮 -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabPlaylist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_notification"
            android:contentDescription="@string/navigation"
            android:layout_marginTop="@dimen/spacing_lg"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
