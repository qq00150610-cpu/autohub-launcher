<?xml version="1.0" encoding="utf-8"?>
<!-- 悬浮导航卡片 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/floating_navigation_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/spacing_md"
    android:background="@drawable/bg_floating_card">

    <!-- 拖动把手 -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="@dimen/drag_handle_width"
        android:layout_height="@dimen/drag_handle_height"
        android:background="@drawable/bg_drag_handle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 导航信息卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/navigation_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/corner_radius_lg"
        app:cardBackgroundColor="@color/card_background_dark"
        app:cardElevation="@dimen/card_elevation"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md">

            <!-- 目的地图标 -->
            <ImageView
                android:id="@+id/destination_icon"
                android:layout_width="@dimen/icon_size_lg"
                android:layout_height="@dimen/icon_size_lg"
                android:src="@drawable/ic_destination"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- 目的地名称 -->
            <TextView
                android:id="@+id/destination_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_size_lg"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toTopOf="@id/destination_icon"
                app:layout_constraintStart_toEndOf="@id/destination_icon"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="公司" />

            <!-- 目的地地址 -->
            <TextView
                android:id="@+id/destination_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:textColor="@color/text_secondary_dark"
                android:textSize="@dimen/text_size_sm"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@id/destination_name"
                app:layout_constraintStart_toEndOf="@id/destination_icon"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="北京市朝阳区建国路88号" />

            <!-- 预计到达时间 -->
            <TextView
                android:id="@+id/eta_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_size_xl"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/destination_address"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="25 分钟" />

            <!-- 剩余距离 -->
            <TextView
                android:id="@+id/distance_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:textColor="@color/text_secondary_dark"
                android:textSize="@dimen/text_size_md"
                app:layout_constraintTop_toTopOf="@id/eta_text"
                app:layout_constraintBottom_toBottomOf="@id/eta_text"
                app:layout_constraintStart_toEndOf="@id/eta_text"
                tools:text="约 12.5 公里" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- 导航控制按钮 -->
    <LinearLayout
        android:id="@+id/navigation_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/navigation_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 取消导航 -->
        <ImageButton
            android:id="@+id/btn_cancel_navigation"
            android:layout_width="@dimen/floating_control_button_size"
            android:layout_height="@dimen/floating_control_button_size"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_floating_control_button"
            android:scaleType="centerInside"
            android:contentDescription="@string/cancel_navigation" />

        <Space
            android:layout_width="@dimen/spacing_lg"
            android:layout_height="match_parent" />

        <!-- 重新规划 -->
        <ImageButton
            android:id="@+id/btn_reroute"
            android:layout_width="@dimen/floating_control_button_size"
            android:layout_height="@dimen/floating_control_button_size"
            android:src="@drawable/ic_reroute"
            android:background="@drawable/bg_floating_control_button"
            android:scaleType="centerInside"
            android:contentDescription="@string/reroute" />

        <Space
            android:layout_width="@dimen/spacing_lg"
            android:layout_height="match_parent" />

        <!-- 全屏导航 -->
        <ImageButton
            android:id="@+id/btn_fullscreen_navigation"
            android:layout_width="@dimen/floating_control_button_size"
            android:layout_height="@dimen/floating_control_button_size"
            android:src="@drawable/ic_fullscreen"
            android:background="@drawable/bg_floating_control_button"
            android:scaleType="centerInside"
            android:contentDescription="@string/fullscreen_navigation" />

    </LinearLayout>

    <!-- 收起/展开按钮 -->
    <ImageButton
        android:id="@+id/btn_toggle_floating"
        android:layout_width="@dimen/floating_control_button_size"
        android:layout_height="@dimen/floating_control_button_size"
        android:src="@drawable/ic_expand_less"
        android:background="@drawable/bg_floating_toggle_button"
        android:scaleType="centerInside"
        android:contentDescription="@string/toggle_floating"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="@dimen/spacing_md" />

</androidx.constraintlayout.widget.ConstraintLayout>
