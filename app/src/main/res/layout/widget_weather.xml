<?xml version="1.0" encoding="utf-8"?>
<!-- 天气组件布局 -->
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/weatherContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_md">

    <!-- 天气图标 -->
    <ImageView
        android:id="@+id/ivWeatherIcon"
        android:layout_width="@dimen/weather_icon_large_size"
        android:layout_height="@dimen/weather_icon_large_size"
        android:src="@drawable/ic_notification"
        android:contentDescription="@string/wallpaper"/>

    <!-- 温度显示 -->
    <TextView
        android:id="@+id/tvTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/weather_temp_size"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/spacing_sm"
        tools:text="25°C"/>

    <!-- 天气描述 -->
    <TextView
        android:id="@+id/tvWeatherDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_size_md"
        android:textColor="@color/text_secondary"
        tools:text="晴朗"/>

    <!-- 附加信息 (湿度、风速等) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_xs">

        <TextView
            android:id="@+id/tvHumidity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_sm"
            android:textColor="@color/text_secondary"
            tools:text="湿度: 45%"/>

        <View
            android:layout_width="@dimen/divider_height"
            android:layout_height="12dp"
            android:layout_marginHorizontal="@dimen/spacing_sm"
            android:background="@color/divider"/>

        <TextView
            android:id="@+id/tvWindSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_sm"
            android:textColor="@color/text_secondary"
            tools:text="风速: 3级"/>
    </LinearLayout>

</LinearLayout>
