<?xml version="1.0" encoding="utf-8"?>
<!-- 单个Dock按钮 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dock_button_container"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Dock图标 -->
    <ImageView
        android:id="@+id/dock_icon"
        android:layout_width="@dimen/dock_icon_size"
        android:layout_height="@dimen/dock_icon_size"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dock_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:src="@drawable/ic_home" />

    <!-- Dock标签文字 -->
    <TextView
        android:id="@+id/dock_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:textColor="@color/text_primary_dark"
        android:textSize="@dimen/text_size_xs"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@id/dock_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="主页" />

    <!-- 通知Badge -->
    <TextView
        android:id="@+id/dock_badge"
        android:layout_width="@dimen/dock_badge_size"
        android:layout_height="@dimen/dock_badge_size"
        android:background="@drawable/bg_dock_badge"
        android:gravity="center"
        android:textColor="@color/text_on_primary"
        android:textSize="@dimen/text_size_xs"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/dock_icon"
        app:layout_constraintEnd_toEndOf="@id/dock_icon"
        tools:text="3"
        tools:visibility="visible" />

    <!-- 选中指示器 -->
    <View
        android:id="@+id/selected_indicator"
        android:layout_width="@dimen/selected_indicator_width"
        android:layout_height="@dimen/selected_indicator_height"
        android:background="@drawable/bg_selected_indicator"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
